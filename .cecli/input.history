+      alert("Failed to scan for printers. Is the backend running on port 8000?");
+    }
+    setIsScanning(false);
+  };
+
+  const handleSaveTemplate = async () => { /* identical code */ };
+  const handleLoadTemplate = (tpl) => { /* identical code */ };
+  const handleUpdateTemplate = async () => { /* identical code */ };
+  const handleDeleteTemplate = async (id) => { /* identical code */ };
+
+  const handlePrint = async () => {
